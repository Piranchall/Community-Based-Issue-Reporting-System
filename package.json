{
  "name": "civic-report-backend",
  "version": "1.0.0",
  "description": "Community-Based Issue Reporting System Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:backend": "nodemon server.js",
    "dev:frontend": "npm run dev --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "migrate": "npx prisma migrate dev",
    "studio": "npx prisma studio",
    "seed": "node -r dotenv/config prisma/seed.js",
    "seed:prisma": "npx prisma db seed"
  },
  "prisma": {
    "seed": "node -r dotenv/config prisma/seed.js"
  },
  "keywords": [
    "civic",
    "reporting",
    "community",
    "issues"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.4",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "prisma": "5.22.0"
  }
}
