# PostgreSQL connection string — same DB as workflow-1
DATABASE_URL=postgresql://user:password@localhost:5432/civicreport

# Secret key for signing admin JWTs (keep separate from workflow-1 JWT_SECRET if desired)
JWT_SECRET=your_super_secret_key_here

# Port — use 5001 to avoid conflict with workflow-1 (5000)
PORT=5001

NODE_ENV=development
